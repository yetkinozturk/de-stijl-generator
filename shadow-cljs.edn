{:source-paths ["src"]

 :dependencies
 []

 ;; Use Bun instead of npm/node for JS deps
 :js-package-manager :bun

 :builds
 {:app
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"

   :modules
   {:main {:init-fn de-stijl.core/init!}}

   :devtools
   {:http-root    "public"
    :http-port    3000
    :reload-cljs  true
    :preloads     [shadow.cljs.devtools.client.browser]}}}}
